{
  "name": "mochi-uv",
  "version": "0.1.0",
  "private": true,
  "description": "mochi UV - 日焼け止め塗り直しリマインダーPWA",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --filter @mochi-uv/web dev",
    "dev:worker": "pnpm --filter @mochi-uv/worker dev",
    "build": "pnpm --filter @mochi-uv/web build && pnpm --filter @mochi-uv/worker build",
    "deploy": "pnpm --filter @mochi-uv/worker deploy"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20"
  }
}
